<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Checklist de Tutoriales</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{
    background:#f4f6f9;
}

.card{
    border:none;
    border-radius:15px;
}

.list-group-item{
    padding:18px;
    transition:.3s;
}

.list-group-item:hover{
    background:#f8f9fa;
}

.form-check-input{
    width:1.4em;
    height:1.4em;
    cursor:pointer;
}

.completado{
    text-decoration:line-through;
    color:gray;
}

.progreso{
    font-size:14px;
    font-weight:bold;
}
</style>
</head>

<body>

<div class="container py-5">

<div class="card shadow">

<div class="card-header bg-primary text-white">
<h2 class="mb-0">📚 Tutoriales</h2>
</div>

<div class="card-body">

<div class="mb-4">

<div class="d-flex justify-content-between mb-2">
<span class="progreso">Progreso</span>
<span id="porcentaje">0%</span>
</div>

<div class="progress" style="height:25px;">
<div id="barra"
class="progress-bar progress-bar-striped progress-bar-animated"
style="width:0%">
</div>
</div>

</div>

<ul class="list-group" id="lista">

<li class="list-group-item">
<div class="form-check">
<input class="form-check-input tarea" type="checkbox">

<label class="form-check-label">
<h5>Introducción</h5>
<p class="mb-0 text-muted">
Conceptos básicos del tutorial.
</p>
</label>
</div>
</li>

<li class="list-group-item">
<div class="form-check">
<input class="form-check-input tarea" type="checkbox">

<label class="form-check-label">
<h5>Instalación</h5>
<p class="mb-0 text-muted">
Preparar el entorno de trabajo.
</p>
</label>
</div>
</li>

<li class="list-group-item">
<div class="form-check">
<input class="form-check-input tarea" type="checkbox">

<label class="form-check-label">
<h5>Primer Proyecto</h5>
<p class="mb-0 text-muted">
Crear la primera aplicación.
</p>
</label>
</div>
</li>

<li class="list-group-item">
<div class="form-check">
<input class="form-check-input tarea" type="checkbox">

<label class="form-check-label">
<h5>Ejercicios</h5>
<p class="mb-0 text-muted">
Practicar lo aprendido.
</p>
</label>
</div>
</li>

<li class="list-group-item">
<div class="form-check">
<input class="form-check-input tarea" type="checkbox">

<label class="form-check-label">
<h5>Proyecto Final</h5>
<p class="mb-0 text-muted">
Completar el proyecto completo.
</p>
</label>
</div>
</li>

</ul>

</div>

</div>

</div>

<script>

const checks=document.querySelectorAll(".tarea");

checks.forEach(check=>{

check.addEventListener("change",actualizar);

});

function actualizar(){

const total=checks.length;

let hechas=0;

checks.forEach(c=>{

if(c.checked){

hechas++;

c.parentElement.querySelector("label").classList.add("completado");

}else{

c.parentElement.querySelector("label").classList.remove("completado");

}

});

const porcentaje=Math.round((hechas/total)*100);

document.getElementById("barra").style.width=porcentaje+"%";

document.getElementById("barra").innerText=porcentaje+"%";

document.getElementById("porcentaje").innerText=porcentaje+"%";

}

</script>

</body>
</html>
